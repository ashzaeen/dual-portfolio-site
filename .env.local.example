# Notion CMS — copy this file to .env.local and fill in values.
# Without these, the site falls back to hardcoded data in /data/*.js.

# Internal integration token from https://www.notion.so/profile/integrations
# Format: ntn_xxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TOKEN=

# Secret that guards the on-demand auto-fill route (/api/notion-autofill).
# Pick any random string; put it in the Notion "Open link" button URL as
# ?key=<value>. If left blank in production the route is OPEN — set it on Vercel.
# Locally it can stay empty (the route runs without auth in dev).
AUTOFILL_SECRET=

# Database IDs (the 32-char hex string in the DB URL, with or without dashes)
# Share each DB with your integration before its ID will work.

# Hero — rotating roles (personal-side typewriter cycle)
NOTION_ROLES_DB_ID=

# Pro Hero — Config (single-row DB)
# One Published row consumed. Required columns:
#   Name             (Title)       — full name (e.g. "Ashzaeen Fatmi Khan")
#   Email            (Rich text)   — contact email (used in mailto link)
#   Resume URL       (URL)         — link the "Download Resume" button points to
#   Location Label   (Rich text)   — e.g. "Dallas Fort Worth, TX"
#   Location Coords  (Rich text)   — e.g. "32.8998° N, 97.0403° W"
#   Status           (Status)      — only "Published" rows render
NOTION_HERO_CONFIG_DB_ID=

# Pro Hero — Role Chips (the 3 small uppercase pills next to the name)
# Columns: Name (Title), Order (Number), Status.
# Optional: Needs Auto-fill (Checkbox) — tick to let watch-notion.mjs set
#   Order=max+1 and Status=Draft, then uncheck. Skip the column if you'd
#   rather number rows manually.
NOTION_HERO_CHIPS_DB_ID=

# Pro Hero — Stats (the 3-card row: Academics / Research Focus / Latest …)
# Columns: Name (Title — eyebrow), Line 1 (Rich text), Line 2 (Rich text),
#          Order (Number), Status. Optional: Needs Auto-fill (Checkbox).
NOTION_HERO_STATS_DB_ID=

# Pro Hero — Ticker Logs (the cycling `> INITIALIZING_…` lines at the bottom)
# Columns: Name (Title — full log line), Order (Number), Status.
# Optional: Needs Auto-fill (Checkbox).
NOTION_HERO_TICKER_DB_ID=

# Hero — Live Status output cache (SHARED between pro and personal Heroes).
# Single Published row, OVERWRITTEN by the regenerate-status cron.
# Columns: Name (Title — generated sentence), Generated At (Date with time),
#          Status (Status).
NOTION_HERO_STATUS_DB_ID=

# Live Status Config — single-row DB the GPT regen pipeline reads from.
# Required columns:
#   Name             (Title)        — row identity (e.g. "Live Status")
#   Current Location (Rich text)    — free-form, fed to GPT
#   Personal Info    (Rich text)    — your context as multi-line text
#   Status Line      (Rich text)    — MANUAL OVERRIDE. If filled, cron pushes
#                                      this text verbatim to the output cache
#                                      (skips GPT). If empty, cron regenerates
#                                      via GPT on its 4hr cadence.
#   Update           (Checkbox)     — tick to trigger an immediate cron action
#                                      on the next hourly tick (regardless of
#                                      cadence). Cron unchecks after processing.
#   Status           (Status)       — only the Published row is consumed
#   (System Prompt lives in the row's PAGE BODY, not a column — open the row
#    in Notion and type the prompt as paragraphs/headings/lists.)
NOTION_LIVE_STATUS_CONFIG_DB_ID=

# Pro Projects — case studies (cards on the Projects section + inline modal)
# Required columns:
#   Name           (Title)            — project name
#   Slug           (Rich text)        — URL slug (auto-derived by watch-notion)
#   Category       (Rich text)        — e.g. "HARDWARE / AI", "SYSTEMS"
#   Award          (Rich text, opt)   — e.g. "🏆 HackUTD: Best Hardware"
#   Summary        (Rich text)        — one-line, shown on the card
#   Tech Stack     (Multi-select)     — stack tags
#   GitHub URL     (URL, opt)         — link bar entry
#   Demo URL       (URL, opt)         — link bar entry
#   Writeup URL    (URL, opt)         — link bar entry (DevPost/blog post)
#   Order          (Number)           — display order
#   Status         (Status)           — only "Published" rows render
# Optional: Needs Auto-fill (Checkbox) — watcher derives Slug, Order=max+1,
#   Status=Draft when ticked, then unchecks.
# Page body = the case study itself (Notion blocks: heading_1/heading_2/
#   callout/code/quote/table/to_do/bulleted_list_item/numbered_list_item/
#   divider/paragraph). Write directly in Notion's editor.
NOTION_PROJECTS_DB_ID=

# Footers — 3 DBs (Pro single-row + Personal single-row + shared Socials)

# Pro Footer (single Published row consumed)
# Required columns:
#   Name             (Title)         — row identity (e.g. "Pro Footer")
#   Avatar Letter    (Rich text)     — single char shown in the glass core circle
#   Footer Name      (Rich text)     — full name shown in the footer
#   Quote            (Rich text)     — the italic line under the name
#   Bottom Tagline   (Rich text)     — "Powered by Tea & Insomnia" etc.
#   Side Label       (Rich text)     — bottom-right corner label ("PROFESSIONAL")
#   Stamp Title      (Rich text)     — "[ High School Website ]"
#   Stamp Subtitle   (Rich text)     — "Maple Leaf International School"
#   Stamp Caption    (Rich text)     — "Class of 2024"
#   Stamp URL        (URL, opt)      — when blank, stamp section hides
#   Status           (Status)        — only "Published" rows render
NOTION_FOOTER_PRO_DB_ID=

# Personal Footer (single Published row consumed)
# Required columns:
#   Name             (Title)
#   Avatar Letter    (Rich text)
#   Footer Name      (Rich text)
#   Quote            (Rich text)     — italic line in the identity block
#   Bottom Tagline   (Rich text)
#   Side Label       (Rich text)     — e.g. "Personal"
#   Stamp Title      (Rich text)     — "High School Website" (line 1 of stamp)
#   Stamp Subtitle   (Rich text)     — "Maple Leaf International School" (line 2)
#   Stamp Caption    (Rich text)     — "Class of 2024" (line 3, full string —
#                                       no prefix added by the renderer)
#   Stamp URL        (URL, opt)      — when blank, stamp section hides
#   Status           (Status)
NOTION_FOOTER_PERSONAL_DB_ID=

# Copyright page — a SINGLE Notion page (not a DB) rendered at /copyright,
# linked from both footers' "Usage & Copyright" link. Always pro-themed.
# Paste the 32-char page ID (everything between the last "-" and the "?"
# in the page URL). Page MUST be shared with the Portfolio SIte integration.
NOTION_COPYRIGHT_PAGE_ID=

# Footer Socials (multi-row, SHARED between pro + personal footers)
# Required columns:
#   Name   (Title)   — label shown under the icon ("GITHUB", "VSCO", etc.)
#   URL    (URL)     — destination
#   Icon   (Select)  — kebab key matched to each footer's icon map
#                       (devpost | github | linkedin | instagram | vsco;
#                        unknown keys render a generic globe fallback)
#   Order  (Number)
#   Status (Status)
# Optional: Needs Auto-fill (Checkbox) — Order + Status defaults via watcher.
NOTION_FOOTER_SOCIALS_DB_ID=

# Pro TechStack — 2 DBs (Categories + Skills joined by relation)
# Component derives angles from Side + index-within-Side: 3 right cats spread
# from -90° to +90°, 3 left cats spread across the other half. Adding a 7th
# category auto-rebalances the spread.

# Categories
# Required columns:
#   Name   (Title)        — "AI & Research"
#   Side   (Select)       — "right" | "left" (fetcher lowercases on read)
#   Order  (Number)       — top→bottom position within its Side (also drives
#                            List view ordering globally)
#   Status (Status)
# Optional: Needs Auto-fill (Checkbox).
NOTION_TECHSTACK_CATEGORIES_DB_ID=

# Skills (one row per skill, related to a Category)
# Required columns:
#   Name     (Title)                   — "Python"
#   Category (Relation → Categories)   — parent category
#   Order    (Number)                  — display order within the category
#   Status   (Status)
# Optional: Needs Auto-fill (Checkbox).
NOTION_TECHSTACK_SKILLS_DB_ID=

# Pro Credentials — 4 DBs (Education / Certifications / Coursework / Curiosity)
# Each is independent; missing env vars fall back per-section.

# Education — degree entries (currently 1, future-proof for Masters/PhD)
# Required columns:
#   Name        (Title)         — degree (e.g. "B.S. Computer Science + Math Minor")
#   Institution (Rich text)     — "University of Texas at Arlington"
#   Date        (Rich text)     — "2023 — 2027"
#   Category    (Rich text)     — eyebrow (e.g. "UNDERGRADUATE")
#   Tags        (Multi-select)  — display chips
#   Order       (Number)
#   Status      (Status)
# Optional: Needs Auto-fill (Checkbox) — Order + Status defaults
NOTION_EDUCATION_DB_ID=

# Certifications — issuer-verified credentials
# Required columns:
#   Name         (Title)         — "AWS Certified AI Practitioner"
#   Issuer       (Rich text)     — "Amazon Web Services"
#   Date         (Rich text)     — "Early 2026" (free-form)
#   Hash         (Rich text)     — "0x8F9A2B4C9D1E7F3A" — user-typed
#   Verification (Select)        — "VERIFIED" | "PENDING" | "EXPIRED" (extensible;
#                                    separate column from publication Status)
#   Link URL     (URL, opt)
#   Link Label   (Rich text, opt) — defaults to "View Credential" if blank
#   Order        (Number)
#   Status       (Status)
# Optional: Needs Auto-fill (Checkbox).
NOTION_CERTIFICATIONS_DB_ID=

# Coursework — bootcamps, training, academic classes
# Required columns:
#   Name     (Title)        — "Advanced Software Engineering"
#   Provider (Rich text)    — "CodePath"
#   Category   (Select)         — "BOOTCAMP" | "TRAINING" | "ACADEMIC" (Notion
#                                   title-cases on create, fetcher upper-cases)
#   Insight    (Rich text, opt) — "what I learned" copy; shown on hover-reveal
#                                   when non-empty (mirrors Curiosity behavior)
#   Link URL   (URL, opt)
#   Link Label (Rich text, opt) — defaults to "View" if blank
#   Order      (Number)
#   Status     (Status)
# Optional: Needs Auto-fill (Checkbox).
NOTION_COURSEWORK_DB_ID=

# Curiosity — videos/repos/docs that shaped your thinking
# Required columns:
#   Name       (Title)         — full title
#   Category   (Select)        — "YOUTUBE" | "GITHUB" | "ANALYSIS" (extensible —
#                                  fetcher upper-cases on read)
#   Insight    (Rich text)     — one-line "what I learned" copy
#   Link URL   (URL, opt)
#   Link Label (Rich text, opt) — defaults by Type (Watch Video / View Repo /
#                                  Read Document)
#   Order      (Number)
#   Status     (Status)
# Optional: Needs Auto-fill (Checkbox).
NOTION_CURIOSITY_DB_ID=

# Pro Experiences — work + extracurricular cards with expandable body
# Required columns:
#   Name         (Title)         — role (e.g. "Research Assistant")
#   Slug         (Rich text)     — URL slug (auto-derived by watch-notion)
#   Kind         (Select)        — "work" | "extracurricular" (splits sections)
#   Category     (Select)        — "RESEARCH" | "PROFESSIONAL" | "LEADERSHIP"
#                                    (add more as needed)
#   Organization (Rich text)
#   Date         (Rich text)     — free-form, e.g. "May 2026 — Present"
#   Tech Stack   (Multi-select)
#   Order        (Number)        — display order within its Kind section
#   Status       (Status)        — only "Published" rows render
# Optional: Needs Auto-fill (Checkbox) — watcher derives Slug, Order=max+1,
#   Status=Draft when ticked, then unchecks.
# Page body = the expanded story (Notion blocks). Rendered with the
# DecryptText scramble animation on paragraph/callout/list content.
NOTION_EXPERIENCES_DB_ID=

# Pro Project Media — gallery items linked to each project
# Required columns:
#   Name       (Title)               — caption / alt text (also shown as
#                                       [ NAME ] placeholder label)
#   Type       (Select)              — "image" | "youtube" | "video"
#   URL        (URL, opt)            — image URL or YouTube watch URL
#   File       (Files & media, opt)  — drag-drop image alternative; site
#                                       prefers File over URL when both set
#   YouTube ID (Rich text, opt)      — auto-parsed from URL on autofill
#                                       when Type=youtube
#   Project    (Relation → Projects) — which project this media belongs to
#   Order      (Number)              — display order in the project's gallery
#   Status     (Status)              — only "Published" rows render
# Optional: Needs Auto-fill (Checkbox) — watcher parses YouTube ID from URL,
#   sets Order=max+1 and Status=Draft.
NOTION_PROJECT_MEDIA_DB_ID=

# Travel — locations (pins), stories (postcards' content), media (images/videos), regions (zoom + grouping metadata)
NOTION_LOCATIONS_DB_ID=
NOTION_STORIES_DB_ID=
NOTION_STORY_MEDIA_DB_ID=
NOTION_REGIONS_DB_ID=

# Music — songs in the crate
NOTION_MUSIC_DB_ID=

# Series — The Screening Room
NOTION_SERIES_DB_ID=

# Writing — The Desk + Archive
NOTION_WRITING_DB_ID=

# Desk decor — polaroids, pinned note, index card stack
NOTION_DESK_DB_ID=

# Section copy — per-section eyebrow / title / intro / instruction for the
# personal sections ("Sections" DB). One Published row per section, Name =
# travel | writing | music | series | gallery. Props: Eyebrow, Title,
# Introduction, Instruction, Mobile Instruction (all rich text), Status. Blank
# cells fall back to the hard-coded copy; Mobile Instruction falls back to
# Instruction. (Optional: add a "Mobile Introduction" column for a shorter
# phone intro — it falls back to Introduction when absent.)
NOTION_SECTIONS_DB_ID=

# Pro section copy — eyebrow / title / intro for the professional sections.
# One Published row per section, Name = projects | experiences |
# experiences-extra | credentials | techstack. Props: Eyebrow, Title,
# Introduction (rich text), Status. Eyebrow is plain text (the ✦ is UI-added).
NOTION_PRO_SECTIONS_DB_ID=

# Personal Hero bio — the line under the name. Single-row DB; props: Name
# (title) + Text (rich text). The first row's Text is the bio.
NOTION_PERSONAL_HERO_DB_ID=

# Pinboard — dynamic photos on The Wall (immersive section).
# Each Published row appears on the immersive wall, placed automatically
# so it doesn't overlap curated items.
#
# Required columns:
#   Title           (Title)         — photo label, e.g. "Ratargul"
#   Photo           (Files & media) — drag your image here (preferred)
#   Image URL       (URL)           — alternative: paste external URL
#   Story           (Rich text)     — modal copy that appears under the photo
#   Width           (Number)        — natural pixel width  (autofill)
#   Height          (Number)        — natural pixel height (autofill)
#   Display H       (Number)        — render height on wall, default 285 (autofill)
#   Mount           (Select)        — "pin" | "tape" | "aged" (default "pin")
#   Pin Color       (Rich text)     — hex color (autofill picks based on photo content)
#   Order           (Number)        — placement order (lower placed first)
#   Wall X          (Number, opt)   — manual override: top-left X on the 3700×2600 wall
#   Wall Y          (Number, opt)   — manual override: top-left Y on the 3700×2600 wall
#                                     (BOTH must be set to take effect; otherwise auto-place)
#   Needs Auto-fill (Checkbox)      — tick to trigger autofill via scripts/watch-notion.mjs
#   Status          (Status)        — only "Published" rows render on the site
#
# Hidden coordinate-discovery editor:
#   Visit /personal?edit=1 → open the wall → drag any photo to find a
#   good spot → copy its (x, y) from the floating panel → paste into
#   the photo's Wall X / Wall Y in Notion → refresh.

# Curated Gallery — copy overrides for the 14 hardcoded curated items.
# Lets you edit their Title / Caption / Tagline in Notion without
# touching code. Image + position stay in data/pinboard.js.
#
# Required columns:
#   Title    (Title)      — display label
#   Key      (Rich text)  — must match an item id in data/pinboard.js:
#                           yjhd, znmd, bd_group, sylhet, boys_suit,
#                           cox_beach, cox_table, cousins, colorado,
#                           boshonto, nobo, family, frontier, subway
#   Caption  (Rich text)  — long modal body copy
#   Tagline  (Rich text)  — italic tagline (posters only: yjhd, znmd)
#   Status   (Status)     — only "Published" rows are read
#   Order    (Number, opt)— sort order for the Notion view
#
# Bootstrap (one-off after creating the DB + columns):
#   node --env-file=.env.local scripts/bootstrap-curated-pinboard.mjs
# Schema check:
#   node --env-file=.env.local scripts/inspect-curated-schema.mjs
NOTION_CURATED_DB_ID=
#
# Autofill (npm run watch:notion):
#   - Reads Photo file → natural Width × Height
#   - Sets Display H (460 for poster-shaped photos h/w>1.3, else 285)
#   - Sends image to gpt-4o-mini vision for content classification:
#     nature → #6b9b65, friends → #c4a050, family → #a85f42, solo → #5b7fa3
#   - Writes back and unchecks the box
#
# NOTE: Notion Files URLs expire ~1 hour after fetch. The site re-fetches
# every revalidate window (1hr) so fresh loads work, but a long-idle tab
# will see images expire — the immersive view surfaces a handwritten
# "refresh the wall" overlay when that happens.
NOTION_PINBOARD_DB_ID=

# OpenAI — used by scripts/watch-notion.mjs (location auto-fill, vision palette,
# music metadata, etc.) AND by app/api/cron/regenerate-status (Live Status GPT).
# Model used: gpt-4o-mini. ~$0.00017 per Live Status regen → roughly $0.001/day
# at the 4hr cadence (6 regens/day).
OPENAI_API_KEY=

# Vercel Cron auth — when set, Vercel injects `Authorization: Bearer ${...}`
# on cron-triggered requests; the regenerate-status route 401's anything else.
# Leave UNSET in local dev so you can hit the route via browser/curl without auth.
# Set to a random long string in your Vercel project's env (Production only).
CRON_SECRET=

# YouTube Data API v3 — optional, enables YouTube ID auto-fill for music
YOUTUBE_API_KEY=

# OMDb — optional, enables Series auto-fill (Seasons/Episodes/Runtime/Years/Genres)
# Free key: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# Last.fm — powers the "now playing / recent track" widget in the Music section
# (app/api/lastfm + /api/lastfm/top). BOTH are required for the feature; if
# either is unset the routes return null and the widget simply hides (no error).
#   LASTFM_API_KEY:  create one at https://www.last.fm/api/account/create
#   LASTFM_USERNAME: your Last.fm profile name (the scrobbling account to read)
LASTFM_API_KEY=
LASTFM_USERNAME=

# PostHog analytics — US cloud, reverse-proxied through /ingest (see
# next.config.mjs rewrites + app/providers.jsx). Only the project API key is
# required; leave it UNSET locally to disable analytics entirely (every
# capture call no-ops — see lib/analytics.js).
#   Project API Key: PostHog → Settings → Project → Project API Key (phc_...)
# This is a PUBLIC key (it ships to the browser) — the NEXT_PUBLIC_ prefix is
# required so Next.js inlines it client-side. Set it in Vercel for Production
# (and Preview, if you want analytics on preview deploys).
NEXT_PUBLIC_POSTHOG_KEY=
